<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LeafEyeTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LeafEyeTest"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LeafEye Database Playground - Async &amp; Filter"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Horizontal"
            Spacing="10">
            <ComboBox
                x:Name="BoxSelector"
                Width="130"
                SelectedIndex="0"
                SelectionChanged="BoxSelector_SelectionChanged">
                <ComboBoxItem Content="User" />
                <ComboBoxItem Content="Profile" />
                <ComboBoxItem Content="History" />
                <ComboBoxItem Content="FileHistory" />
            </ComboBox>

            <Button Click="AddDummyData_Click" Content="Add 5 Dummy" />
            <Button Click="ClearBox_Click" Content="Clear Box" />

            <AppBarSeparator />

            <ToggleButton
                x:Name="SortToggle"
                Click="SortToggle_Click"
                Content="Sort: Descending"
                IsChecked="True" />

            <ProgressRing
                x:Name="LoadingRing"
                Width="20"
                Height="20"
                Margin="10,0,0,0"
                IsActive="False" />
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,15"
            Orientation="Horizontal"
            Spacing="10">
            <TextBox
                x:Name="SearchBox"
                Width="200"
                VerticalAlignment="Center"
                PlaceholderText="Cari teks..." />

            <StackPanel
                x:Name="DateRangePanel"
                Orientation="Horizontal"
                Spacing="5"
                Visibility="Collapsed">
                <CalendarDatePicker
                    x:Name="StartDatePicker"
                    Width="150"
                    PlaceholderText="Start Date" />
                <TextBlock VerticalAlignment="Center" Text="to" />
                <CalendarDatePicker
                    x:Name="EndDatePicker"
                    Width="150"
                    PlaceholderText="End Date" />
            </StackPanel>

            <Button
                Click="SearchButton_Click"
                Content="Cari"
                Style="{StaticResource AccentButtonStyle}" />
            <Button Click="ResetButton_Click" Content="Reset" />
        </StackPanel>

        <ListView
            x:Name="DataListView"
            Grid.Row="2"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="4">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock
                        Margin="0,8"
                        FontFamily="Consolas"
                        FontSize="12"
                        Text="{Binding}"
                        TextWrapping="Wrap" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel
            Grid.Row="3"
            Margin="0,15,0,0"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Spacing="15">
            <Button
                x:Name="PrevButton"
                Click="PrevButton_Click"
                Content="&lt; Prev" />
            <TextBlock
                x:Name="PageInfoText"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Text="Page 1 of ?" />
            <Button
                x:Name="NextButton"
                Click="NextButton_Click"
                Content="Next &gt;" />
        </StackPanel>

        <TextBlock
            x:Name="StatusText"
            Grid.Row="4"
            Margin="0,10,0,0"
            FontSize="12"
            FontWeight="Bold" />
    </Grid>
</Window>