<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LeafEyeTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LeafEye Database Dashboard"
    mc:Ignorable="d">

    <Grid>
        <StackPanel
            x:Name="LoginPanel"
            Width="320"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="15"
            Visibility="Visible">
            <TextBlock
                Margin="0,0,0,10"
                HorizontalAlignment="Center"
                FontSize="24"
                FontWeight="Bold"
                Text="Welcome to LeafEye" />

            <TextBox
                x:Name="LoginUsername"
                Header="Username"
                PlaceholderText="Enter username" />

            <PasswordBox
                x:Name="LoginPassword"
                Header="Password"
                PlaceholderText="Enter password" />

            <Button
                x:Name="LoginButton"
                HorizontalAlignment="Stretch"
                Click="LoginButton_Click"
                Content="Login"
                Style="{StaticResource AccentButtonStyle}" />

            <TextBlock
                x:Name="LoginErrorText"
                HorizontalAlignment="Center"
                Foreground="Red"
                TextWrapping="Wrap" />

            <MenuFlyoutSeparator Margin="0,10,0,10" />

            <Button
                HorizontalAlignment="Stretch"
                Click="InitDb_Click"
                Content="Initialize Database" />
            <Button
                HorizontalAlignment="Stretch"
                Click="SeedDb_Click"
                Content="Seed Mock Data" />
        </StackPanel>

        <NavigationView
            x:Name="MainNav"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="Left"
            SelectionChanged="MainNav_SelectionChanged"
            Visibility="Collapsed">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Users"
                    Icon="People"
                    Tag="Users" />
                <NavigationViewItem
                    Content="Profiles"
                    Icon="ContactInfo"
                    Tag="Profiles" />
                <NavigationViewItem
                    Content="History"
                    Icon="Clock"
                    Tag="History" />
                <NavigationViewItem
                    Content="File History"
                    Icon="Document"
                    Tag="FileHistory" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Content="Logout"
                    Icon="Cancel"
                    Tag="Logout"
                    Tapped="Logout_Tapped" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Padding="20" />

        </NavigationView>
    </Grid>
</Window>