import "Result.idl";
import "ProfileModel.idl";
import "UserModel.idl";
import "HistoryModel.idl";
import "FileHistoryModel.idl";

namespace LeafEyeCore {

    [default_interface]
    runtimeclass Database
    {
        // Constructors
        Database();
        Database(String database_location, UInt64 max_db_size);

        void TxWrite();
        void TxRead();
        void TxSuccess();

        // Lifecycle
        Windows.Foundation.IAsyncOperation<Result> InitializeAsync();

        // ─── User ────────────────────────────────────────────────
        Windows.Foundation.IAsyncOperation<Result> GetUserById(UInt64 id);
        Windows.Foundation.IAsyncOperation<Result> GetUserByAccessLevel(Boolean is_admin,Int32 offset, Int32 limit);
        Windows.Foundation.IAsyncOperation<Result> GetUserByUsername(String username);
        Windows.Foundation.IAsyncOperation<Result> GetUserContainsUsername(String username, Int32 offset, Int32 limit);
        Windows.Foundation.IAsyncOperation<Result> GetAllUsers(Int32 offset, Int32 limit);
        Windows.Foundation.IAsyncOperation<Result> ValidateUserCredentials(String username, String password);
        Windows.Foundation.IAsyncOperation<Result> AddUser(UserModel user);
        Windows.Foundation.IAsyncOperation<Result> UpdateUser(UserModel user);
        Windows.Foundation.IAsyncOperation<Result> DeleteUser(UInt64 id);

        Windows.Foundation.IAsyncOperation<Result> GetUserCountByAccessLevel(Boolean is_admin);
        Windows.Foundation.IAsyncOperation<Result> GetUserCountContainsUsername(String username);
        Windows.Foundation.IAsyncOperation<Result> GetUserCount();

        // ─── Profile ─────────────────────────────────────────────
        Windows.Foundation.IAsyncOperation<Result> GetProfileById(UInt64 profileId);
        Windows.Foundation.IAsyncOperation<Result> GetUserProfileByLink(UInt64 userId);
        Windows.Foundation.IAsyncOperation<Result> AddUserProfile(ProfileModel userProfile);
        Windows.Foundation.IAsyncOperation<Result> UpdateUserProfile(ProfileModel userProfile);
        Windows.Foundation.IAsyncOperation<Result> DeleteUserProfile(UInt64 id);

        // ─── History ─────────────────────────────────────────────
        Windows.Foundation.IAsyncOperation<Result> GetHistoryById(UInt64 id);
        Windows.Foundation.IAsyncOperation<Result> GetHistoryByUserLink(UInt64 userId, Int32 offset, Int32 limit);
        Windows.Foundation.IAsyncOperation<Result> GetHistoryByStatus(Int32 status, Int32 offset, Int32 limit);
        Windows.Foundation.IAsyncOperation<Result> GetHistoryByDateRange(UInt64 start, UInt64 end, Int32 offset, Int32 limit);
        Windows.Foundation.IAsyncOperation<Result> AddHistory(HistoryModel history);
        Windows.Foundation.IAsyncOperation<Result> UpdateHistory(HistoryModel history);
        Windows.Foundation.IAsyncOperation<Result> DeleteHistory(UInt64 id);

        // ─── File History ─────────────────────────────────────────
        Windows.Foundation.IAsyncOperation<Result> GetFileHistoryById(UInt64 id);
        Windows.Foundation.IAsyncOperation<Result> GetFileHistoriesByHistoryLink(UInt64 historyId, Int32 page, Int32 pageSize);
        Windows.Foundation.IAsyncOperation<Result> GetFileHistoriesByConfidenceThreshold(Double minConfidence, Int32 page, Int32 pageSize);
        Windows.Foundation.IAsyncOperation<Result> AddFileHistory(FileHistoryModel fileHistory);
        Windows.Foundation.IAsyncOperation<Result> UpdateFileHistory(FileHistoryModel fileHistory);
        Windows.Foundation.IAsyncOperation<Result> DeleteFileHistory(UInt64 id);

        // Add these inside your Database runtimeclass
        Windows.Foundation.IAsyncOperation<Result> LinkUserProfile(UInt64 userId, UInt64 profileId);
        Windows.Foundation.IAsyncOperation<Result> LinkHistoryToUser(UInt64 historyId, UInt64 userId);
        Windows.Foundation.IAsyncOperation<Result> LinkFileHistoryToHistory(UInt64 fileHistoryId, UInt64 historyId); 
    }
}
