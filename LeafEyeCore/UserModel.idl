    [default_interface]
    runtimeclass UserModel : Microsoft.UI.Xaml.Data.INotifyPropertyChanged
    {
        
        UserModel();
        UserModel(String username, String password, Boolean isAdmin);
        
        UInt64 Id{get;set;};
        String Username{get;set;};
