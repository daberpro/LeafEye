<Page
    x:Class="LeafEye.UsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:LeafEyeCore"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LeafEye"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <core:StringFormatConverter x:Key="FormatConverter" />
    </Page.Resources>

    <Grid Padding="32" RowDefinitions="Auto,*">

        <Grid
            Grid.Row="0"
            Margin="0,0,0,24"
            ColumnDefinitions="*,Auto">
            <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Manajemen Pengguna" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="Kelola daftar pengguna, peran, dan hak akses sistem LeafEye." />
            </StackPanel>

            <CommandBar
                Grid.Column="1"
                Background="Transparent"
                DefaultLabelPosition="Right"
                IsOpen="False">
                <AppBarElementContainer Margin="0,0,12,0" VerticalAlignment="Center">
                    <AutoSuggestBox
                        x:Name="SearchBar"
                        Width="240"
                        PlaceholderText="Cari username..."
                        QueryIcon="Find"
                        TextChanged="SearchBar_TextChanged" />
                </AppBarElementContainer>

                <AppBarElementContainer Margin="0,0,12,0" VerticalAlignment="Center">
                    <ComboBox
                        x:Name="AccessLevel"
                        Width="150"
                        PlaceholderText="Filter level"
                        SelectionChanged="AccessLevel_SelectionChanged">
                        <ComboBoxItem Content="Semua Level" />
                        <ComboBoxItem Content="Admin" />
                        <ComboBoxItem Content="User" />
                    </ComboBox>
                </AppBarElementContainer>

                <AppBarButton
                    x:Name="AddUserButton"
                    Click="AddUserButton_Click"
                    Icon="Add"
                    Label="Tambah User" />
            </CommandBar>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="380,24,*">

            <Border
                Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid
                        Padding="16"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="Daftar Pengguna" />
                        <ComboBox
                            x:Name="PageSize"
                            Width="68"
                            HorizontalAlignment="Right"
                            SelectedIndex="2"
                            SelectionChanged="PageSize_SelectionChanged">
                            <ComboBoxItem Content="5" />
                            <ComboBoxItem Content="10" />
                            <ComboBoxItem Content="20" />
                            <ComboBoxItem Content="50" />
                        </ComboBox>
                    </Grid>

                    <RefreshContainer
                        x:Name="UserRefreshContainer"
                        Grid.Row="1"
                        RefreshRequested="UserRefreshContainer_RefreshRequested">
                        <ListView
                            x:Name="UserListView"
                            Padding="0,8"
                            IsItemClickEnabled="True"
                            ItemClick="UserListView_ItemClick"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="core:UserModel">
                                    <Grid Padding="12,8" ColumnDefinitions="Auto,*,Auto">
                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="2">
                                            <TextBlock
                                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                Text="{x:Bind Username}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Text="{x:Bind local:UsersPage.ConvertToUserStatus(IsAdmin)}" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="4">
                                            <Button
                                                x:Name="UpdateUserBtn"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="UpdateUserBtn_Click"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Update">
                                                <FontIcon
                                                    FontSize="14"
                                                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                    Glyph="&#xE70F;" />
                                            </Button>
                                            <Button
                                                x:Name="DeleteUserBtn"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="DeleteUserBtn_Click"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Delete">
                                                <FontIcon
                                                    FontSize="14"
                                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                    Glyph="&#xE74D;" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </RefreshContainer>

                    <StackPanel
                        Grid.Row="2"
                        Padding="12"
                        HorizontalAlignment="Center"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Orientation="Horizontal"
                        Spacing="24">
                        <Button
                            x:Name="PrevPageBtn"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="PrevPageButton_Click"
                            IsEnabled="{x:Bind PrevPageEnabled, Mode=OneWay}">
                            <FontIcon FontSize="12" Glyph="&#xE76B;" />
                        </Button>
                        <TextBlock
                            x:Name="PageInfoText"
                            VerticalAlignment="Center"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="{x:Bind GetPaginationInfo, Mode=OneWay}" />
                        <Button
                            x:Name="NextPageBtn"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="NextPageButton_Click"
                            IsEnabled="{x:Bind NextPageEnabled, Mode=OneWay}">
                            <FontIcon FontSize="12" Glyph="&#xE76C;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Column="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
                    <PersonPicture
                        Width="140"
                        Height="140"
                        DisplayName="{x:Bind Profile.Fullname, Mode=OneWay}"
                        ProfilePicture="{x:Bind Profile.AvatarPath, Mode=OneWay}" />

                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{ThemeResource TitleTextBlockStyle}"
                            Text="{x:Bind Profile.Fullname, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="{x:Bind core:UserRoleHelper.ConvertUserIntRoleToString(Profile.Role), Mode=OneWay}" />
                    </StackPanel>

                    <Rectangle
                        Width="200"
                        Height="1"
                        Margin="0,5"
                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <TextBlock
                        MaxWidth="280"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Pilih pengguna dari daftar untuk melihat detail lengkap atau mengubah hak akses."
                        TextAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>