<Page
    x:Class="LeafEye.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:LeafEyeCore"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LeafEye"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="40" RowDefinitions="Auto, *, Auto">

        <Grid
            Grid.Row="0"
            Margin="0,0,0,24"
            ColumnDefinitions="*, Auto">
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Spacing="4">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Deteksi penyakit" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="Upload gambar daun untuk mendeteksi penyakit." />
            </StackPanel>

            <Button
                x:Name="SelectFolderOutputButton"
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="SelectFolderOutputButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                    <TextBlock Text="Pilih Folder Output" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid
                x:Name="DropTarget"
                Grid.Column="0"
                AllowDrop="True"
                DragLeave="DropTarget_DragLeave"
                DragOver="DropTarget_DragOver"
                Drop="DropTarget_Drop">

                <Rectangle
                    Fill="{ThemeResource LayerFillColorAltBrush}"
                    RadiusX="8"
                    RadiusY="8"
                    Stroke="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                    StrokeDashArray="4 4"
                    StrokeThickness="2" />

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="20">

                    <Border
                        Width="72"
                        Height="72"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="36">
                        <FontIcon
                            FontSize="28"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Glyph="&#xE8B0;" />
                    </Border>

                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Text="Drag &amp; Drop gambar di sini" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="atau klik tombol di bawah" />
                    </StackPanel>

                    <Button
                        x:Name="FilePicker"
                        HorizontalAlignment="Center"
                        Click="FilePicker_Click"
                        Content="Pilih File" />
                </StackPanel>
            </Grid>

            <Border
                Grid.Column="1"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowDefinitions="Auto, *">

                    <Grid
                        Grid.Row="0"
                        Margin="0,0,0,16"
                        ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="4">
                            <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Antrian File" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xEC50;" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Text="{x:Bind HistoryInfo.OutputFolder, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind HistoryInfo.OutputFolder, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="12">
                            <CheckBox
                                x:Name="SelectAllFilesCheckBox"
                                Margin="0"
                                VerticalAlignment="Center"
                                Content="Pilih Semua" />

                            <Button
                                x:Name="DeleteSelectedFilesButton"
                                Padding="8"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="DeleteSelectedFilesButton_Click"
                                ToolTipService.ToolTip="Hapus file terpilih">
                                <FontIcon
                                    FontSize="14"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    Glyph="&#xE74D;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        x:Name="EmptyFileHistoryListViewText"
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Text="Tidak ada file dalam antrian. Tambahkan file untuk memulai." />

                    <ListView
                        x:Name="FileHistoryListView"
                        Grid.Row="1"
                        SelectionMode="None"
                        ShowsScrollingPlaceholders="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:FileItemsHomePageModel">
                                <Border
                                    Padding="12"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto, Auto, *, Auto">

                                        <CheckBox
                                            Grid.Column="0"
                                            MinWidth="0"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Center"
                                            IsChecked="{x:Bind Selected, Mode=TwoWay}" />

                                        <Border
                                            Grid.Column="1"
                                            Width="48"
                                            Height="48"
                                            Margin="0,0,16,0"
                                            Background="{ThemeResource LayerFillColorAltBrush}"
                                            CornerRadius="6">
                                            <Image Source="{x:Bind FilePath, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Spacing="2">
                                            <TextBlock
                                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                Text="{x:Bind FileName, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{x:Bind FileName, Mode=OneWay}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Text="{x:Bind local:HomePage.ConvertToDateTimeString(DateCreated)}" />
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="{x:Bind local:HomePage.ConvertToFileSizeString(FileSize), Mode=OneWay}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>

        </Grid>

        <Border
            Grid.Row="2"
            Margin="0,24,0,0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <ProgressBar x:Name="ProgressBar" Grid.Row="0" MinHeight="6" Value="0" />
                <Grid Padding="24" Grid.Row="1" ColumnDefinitions="*, Auto">
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Spacing="4">
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind ProcessButtonInfo, Mode=OneWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="2 file terpilih dalam 1 batch." />
                    </StackPanel>
                    <Button
                        x:Name="ProcessButton"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Click="ProcessButton_Click"
                        IsEnabled="{x:Bind IsProcessButtonEnabled, Mode=OneWay}"
                        Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE768;" />
                            <TextBlock Text="Mulai Proses" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
            
        </Border>

    </Grid>
</Page>