<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LeafEye.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:LeafEyeCore"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LeafEye"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="40" RowDefinitions="Auto, *">

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Riwayat Pemindaian" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="Lihat dan kelola hasil pemindaian sebelumnya." />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="12">
                <CalendarDatePicker VerticalAlignment="Center" PlaceholderText="Tanggal Mulai" />
                <TextBlock
                    Margin="0,0,0,4"
                    VerticalAlignment="Center"
                    Text="-" />
                <CalendarDatePicker VerticalAlignment="Center" PlaceholderText="Tanggal Akhir" />

                <ComboBox
                    Width="120"
                    VerticalAlignment="Center"
                    PlaceholderText="Pilih Status">
                    <ComboBoxItem Content="Semua" />
                    <ComboBoxItem Content="Selesai" />
                    <ComboBoxItem Content="Proses" />
                    <ComboBoxItem Content="Gagal" />
                </ComboBox>

                <Button VerticalAlignment="Center" Style="{StaticResource ShadcnOutlineButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE7ad;" />
                        <TextBlock Text="Export CSV" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <SplitView
            Grid.Row="1"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="400"
            PaneBackground="Transparent">

            <SplitView.Pane>
                <Border
                    Margin="0,0,24,0"
                    Padding="0"
                    Style="{StaticResource ShadcnCardStyle}">
                    <Grid RowDefinitions="Auto, *, Auto">

                        <Grid
                            Padding="16,12"
                            Background="{ThemeResource LayerFillColorAltBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            ColumnDefinitions="*, *">
                            <StackPanel
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,10,0"
                                    FontSize="14"
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    Text="Sesi Terakhir" />
                                <ComboBox
                                    x:Name="PageSize"
                                    Width="70"
                                    VerticalAlignment="Center"
                                    PlaceholderText="10"
                                    SelectionChanged="PageSize_SelectionChanged">
                                    <ComboBoxItem Content="2" />
                                    <ComboBoxItem Content="5" />
                                    <ComboBoxItem Content="10" IsSelected="True" />
                                    <ComboBoxItem Content="20" />
                                    <ComboBoxItem Content="30" />
                                    <ComboBoxItem Content="40" />
                                    <ComboBoxItem Content="50" />
                                </ComboBox>
                            </StackPanel>
                            <TextBlock
                                Grid.Column="1"
                                FontSize="14"
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="Status"
                                TextAlignment="Center" />
                        </Grid>

                        <ListView
                            x:Name="HistoryListView"
                            Grid.Row="1"
                            Padding="0,8"
                            IsItemClickEnabled="True"
                            ItemClick="HistoryListView_ItemClick"
                            SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="16,12" />
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="core:HistoryModel">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind local:HistoryPage.ConvertToDateTimeString(Date), Mode=OneWay}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind local:HistoryPage.ConvertTotalFileToString(TotalFiles), Mode=OneWay}" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            Padding="8,2"
                                            Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                            CornerRadius="4">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                Text="Selesai" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>


                        </ListView>

                        <Border
                            Grid.Row="2"
                            Padding="12"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                            <StackPanel
                                HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="16">
                                <Button
                                    x:Name="PreviousPageButton"
                                    Padding="8,4"
                                    Click="PreviousPageButton_Click"
                                    Style="{StaticResource ShadcnOutlineButtonStyle}"
                                    ToolTipService.ToolTip="Previous Page">
                                    <FontIcon FontSize="12" Glyph="&#xE76B;" />
                                </Button>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind GetPaginationInfo, Mode=OneWay}" />
                                <Button
                                    x:Name="NextPageButton"
                                    Padding="8,4"
                                    Click="NextPageButton_Click"
                                    Style="{StaticResource ShadcnOutlineButtonStyle}"
                                    ToolTipService.ToolTip="Next Page">
                                    <FontIcon FontSize="12" Glyph="&#xE76C;" />
                                </Button>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>
            </SplitView.Pane>

            <SplitView.Content>
                <Border Margin="0" Style="{StaticResource ShadcnCardStyle}">
                    <Grid RowDefinitions="Auto, Auto, *">

                        <Grid Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind local:HistoryPage.HistoryIdToStringConverter(SelectedHistory.Id), Mode=OneWay}" />
                                <StackPanel
                                    Margin="0,4,0,0"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <FontIcon
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xEC50;" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind SelectedHistory.OutputFolder, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <MenuFlyoutSeparator Grid.Row="1" Margin="0,0,0,16" />

                        <TextBlock
                            x:Name="EmptyFileHistoryListViewText"
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Silahkan tekan riwayat untuk melihat file - file." />

                        <ListView
                            x:Name="FileHistoryListView"
                            Grid.Row="2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="core:FileHistoryModel">
                                    <Border
                                        Padding="12"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Grid ColumnDefinitions="Auto, *, Auto, Auto">

                                            <Border
                                                Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                Margin="0,0,16,0"
                                                Background="{ThemeResource LayerFillColorAltBrush}"
                                                CornerRadius="4">
                                                <Image Source="{x:Bind local:HistoryPage.CheckFilePath(FilePath), Mode=OneWay}" Stretch="UniformToFill" />
                                            </Border>

                                            <StackPanel
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind FileName, Mode=OneWay}" />
                                                <TextBlock
                                                    Foreground="{StaticResource BrandPrimaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Sakit (Spot)" />
                                            </StackPanel>

                                            <StackPanel
                                                Grid.Column="2"
                                                Margin="0,0,16,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Confidence" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource BodyTextBlockStyle}"
                                                    Text="{x:Bind ConfidenceScore, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </Grid>
                </Border>
            </SplitView.Content>

        </SplitView>
    </Grid>
</Page>