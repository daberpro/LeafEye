<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LeafEye.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LeafEye"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="40" MinWidth="700">
            <Grid HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Section -->
                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,32">
                    <TextBlock Text="Kelola informasi pribadi dan keamanan akun Anda." 
                               Style="{StaticResource BodyTextBlockStyle}" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Main Content Grid -->
                <Grid Grid.Row="1" ColumnSpacing="24" RowSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" MinWidth="320" MaxWidth="420"/>
                        <ColumnDefinition Width="2*" MinWidth="450"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column - Profile Card -->
                    <Border Grid.Column="0" 
                            Style="{StaticResource ShadcnCardStyle}" 
                            VerticalAlignment="Top">
                        <Grid RowSpacing="24" Padding="0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Profile Picture -->
                            <PersonPicture Grid.Row="0"
                                           DisplayName="Admin User" 
                                           Initials="AD" 
                                           Height="100" 
                                           Width="100"
                                           HorizontalAlignment="Center"/>

                            <!-- Name and Role -->
                            <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Admin User" 
                                           Style="{StaticResource SubtitleTextBlockStyle}" 
                                           HorizontalAlignment="Center" 
                                           FontWeight="Bold"/>

                                <Border Background="{ThemeResource Green100}" 
                                        BorderBrush="{ThemeResource Green300}" 
                                        BorderThickness="1" 
                                        CornerRadius="12" 
                                        Padding="12,4" 
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="Administrator" 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource Green800}" 
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <!-- Separator -->
                            <MenuFlyoutSeparator Grid.Row="2"/>

                            <!-- User Info -->
                            <Grid Grid.Row="3" RowSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- User ID -->
                                <Grid Grid.Row="0" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE77B;" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="ID Pengguna" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" 
                                               Text="#882190" 
                                               HorizontalAlignment="Right" 
                                               FontWeight="Medium"/>
                                </Grid>

                                <!-- Join Date -->
                                <Grid Grid.Row="1" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE716;" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="Bergabung" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" 
                                               Text="12 Feb 2026" 
                                               HorizontalAlignment="Right" 
                                               FontWeight="Medium"/>
                                </Grid>

                                <!-- Total Detections -->
                                <Grid Grid.Row="2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE9D2;" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="Total Deteksi" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" 
                                               Text="1,240 File" 
                                               HorizontalAlignment="Right" 
                                               FontWeight="Medium"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Right Column - Security & Logout -->
                    <Grid Grid.Column="1" RowSpacing="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Security Card -->
                        <Border Grid.Row="0" Style="{StaticResource ShadcnCardStyle}">
                            <Grid RowSpacing="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Spacing="4">
                                    <TextBlock Text="Keamanan Akun" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                    <TextBlock Text="Perbarui kata sandi Anda secara berkala." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Separator -->
                                <MenuFlyoutSeparator Grid.Row="1" Opacity="0.5"/>

                                <!-- Form Fields -->
                                <Grid Grid.Row="2" RowSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Username -->
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <TextBlock Text="Username" FontWeight="Medium"/>
                                        <TextBox Text="admin_user" IsReadOnly="True" IsEnabled="False" Opacity="0.7"/>
                                    </StackPanel>

                                    <!-- Old Password -->
                                    <StackPanel Grid.Row="1" Spacing="8">
                                        <TextBlock Text="Kata Sandi Lama" FontWeight="Medium"/>
                                        <PasswordBox PlaceholderText="Masukkan kata sandi saat ini"/>
                                    </StackPanel>

                                    <!-- New Password Grid -->
                                    <Grid Grid.Row="2" ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Spacing="8">
                                            <TextBlock Text="Kata Sandi Baru" FontWeight="Medium"/>
                                            <PasswordBox PlaceholderText="Minimal 8 karakter"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <TextBlock Text="Konfirmasi Kata Sandi" FontWeight="Medium"/>
                                            <PasswordBox PlaceholderText="Ulangi kata sandi baru"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <!-- Action Buttons -->
                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="1" 
                                                Orientation="Horizontal" 
                                                Spacing="12" 
                                                HorizontalAlignment="Right">
                                        <Button Content="Batal" 
                                                Style="{StaticResource ShadcnOutlineButtonStyle}" 
                                                Width="100"/>
                                        <Button Style="{StaticResource ShadcnPrimaryButtonStyle}" 
                                                Width="120">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                                <TextBlock Text="Simpan"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Logout Card -->
                        <Border Grid.Row="1"
                                Style="{StaticResource ShadcnCardStyle}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="24"
                                Background="Transparent">

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" 
                                            Spacing="4" 
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Keluar dari Sesi" 
                                               Style="{StaticResource BodyStrongTextBlockStyle}" 
                                               Foreground="#DC2626"/>
                                    <TextBlock Text="Akhiri sesi Anda saat ini. Anda harus login kembali untuk masuk." 
                                               Style="{StaticResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                        Style="{StaticResource ShadcnOutlineButtonStyle}" 
                                        BorderBrush="#FCA5A5" 
                                        Background="Transparent"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7E8;" Foreground="#DC2626"/>
                                        <TextBlock Text="Log out" Foreground="#DC2626"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>