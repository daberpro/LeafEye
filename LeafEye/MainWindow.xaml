<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LeafEye.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LeafEye"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="LeafEye"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="LeafEye"
            Grid.Row="0"
            BackRequested="AppTitleBar_BackRequested"
            Background="{ThemeResource ControlFillColorDefaultBrush}"
            IsBackButtonEnabled="False"
            IsBackButtonVisible="True"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="AppTitleBar_PaneToggleRequested"
            Subtitle="v1.0.0">

            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/StoreLogo.png" />
            </TitleBar.IconSource>

            <TitleBar.RightHeader>
                <Grid>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <PersonPicture
                            x:Name="ProfilePic"
                            Width="30"
                            Height="30"
                            Margin="0,0,10,0"
                            Initials="JD"
                            Tapped="ProfilePic_Tapped" />
                        <ToggleSwitch
                            x:Name="ThemeToggleSwitch"
                            IsOn="True"
                            OffContent="Light"
                            OnContent="Dark"
                            Toggled="ToggleSwitch_Toggled" />
                    </StackPanel>
                </Grid>
            </TitleBar.RightHeader>
        </TitleBar>

        <NavigationView
            x:Name="AppNavigationView"
            Grid.Row="1"
            Background="{ThemeResource ControlFillColorDefaultBrush}"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False"
            IsPaneToggleButtonVisible="False"
            ItemInvoked="NavigationView_ItemInvoked"
            Loaded="NavigationView_Loaded"
            PaneDisplayMode="LeftCompact">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Home"
                    Icon="Home"
                    Tag="HomePage" />
                <NavigationViewItem
                    Content="History"
                    Icon="Folder"
                    Tag="HistoryPage" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Content="Profile"
                    Icon="Contact"
                    Tag="ProfilePage" />
            </NavigationView.FooterMenuItems>

            <NavigationView.Content>
                <Frame
                    x:Name="contentFrame"
                    Padding="16,0,15,0"
                    Navigated="contentFrame_Navigated" />
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Window>