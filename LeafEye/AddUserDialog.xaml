<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="LeafEye.AddUserDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tambah User Baru"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
    BorderThickness="1"
    CloseButtonStyle="{StaticResource ShadcnOutlineButtonStyle}"
    CloseButtonText="Batal"
    CornerRadius="8"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    PrimaryButtonStyle="{StaticResource ShadcnPrimaryButtonStyle}"
    PrimaryButtonText="Simpan">

    <StackPanel
        Width="320"
        Margin="0,16,0,0"
        Spacing="16">

        <InfoBar
            x:Name="StatusInfoBar"
            IsClosable="True"
            IsOpen="False"
            Message="" />

        <StackPanel Spacing="8">
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Username" />
            <TextBox
                x:Name="UsernameTextBox"
                CornerRadius="6"
                KeyDown="UsernameTextBox_KeyDown"
                PlaceholderText="Masukkan username..." />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Password" />
            <PasswordBox
                x:Name="PasswordBox"
                CornerRadius="6"
                KeyDown="PasswordBox_KeyDown"
                PlaceholderText="Masukkan password..." />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Pilih Role" />
            <ComboBox
                x:Name="RoleComboBox"
                CornerRadius="6"
                SelectionChanged="RoleComboBox_SelectionChanged">
                <ComboBoxItem Content="Manajer" Tag="0" />
                <ComboBoxItem Content="Staff" Tag="1" />
                <ComboBoxItem Content="Koordinator" Tag="2" />
                <ComboBoxItem
                    Content="Tamu"
                    IsSelected="True"
                    Tag="3" />
            </ComboBox>
        </StackPanel>

        <CheckBox
            x:Name="IsAdminCheckBox"
            Margin="0,4,0,0"
            Content="Jadikan sebagai Admin" />

    </StackPanel>
</ContentDialog>