<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LeafEye.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LeafEye"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5.5*" />
            <ColumnDefinition Width="4.5*" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Column="0"
            Padding="48"
            Background="{ThemeResource SystemControlHighlightAccentBrush}"
            RequestedTheme="Dark">

            <StackPanel
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon FontSize="24" Glyph="&#xE1A5;" />
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Text="LeafEye" />
            </StackPanel>

            <StackPanel
                MaxWidth="500"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Spacing="16">
                <TextBlock
                    FontSize="64"
                    FontWeight="Bold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    LineHeight="72"
                    Text="Hello&#x0a;LeafEye!" />
                <TextBlock
                    FontSize="16"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Sistem cerdas deteksi penyakit daun durian. Lewati tugas manual, tingkatkan produktivitas konservasi, dan hemat waktu Anda!"
                    TextWrapping="Wrap" />
            </StackPanel>

            <TextBlock
                VerticalAlignment="Bottom"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="© 2026 Alam Sehat Lestari (ASRI). All rights reserved." />
        </Grid>

        <Grid Grid.Column="1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel
                MaxWidth="420"
                Padding="48"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Spacing="24">

                <StackPanel Margin="0,0,0,16" Spacing="8">
                    <TextBlock
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Text="Selamat Datang!" />
                    <TextBlock
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Silakan masuk ke akun Anda untuk mengakses sistem."
                        TextWrapping="Wrap" />
                </StackPanel>

                <InfoBar
                    x:Name="ErrorBar"
                    Title="Login Gagal"
                    IsClosable="True"
                    IsOpen="False"
                    Message="Username atau password yang Anda masukkan salah."
                    Severity="Error" />

                <StackPanel Spacing="16">
                    <TextBox
                        x:Name="UsernameInput"
                        CornerRadius="6"
                        Header="Username"
                        PlaceholderText="Masukkan username" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock
                                VerticalAlignment="Bottom"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="Password" />
                            <HyperlinkButton
                                MinHeight="0"
                                Padding="0"
                                HorizontalAlignment="Right"
                                Content="Lupa password?"
                                FontSize="12" />
                        </Grid>

                        <PasswordBox
                            x:Name="PasswordInput"
                            Grid.Row="1"
                            CornerRadius="6" />
                    </Grid>
                </StackPanel>

                <Button
                    Height="40"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    Click="Button_Click"
                    Content="Masuk Sekarang"
                    CornerRadius="6"
                    Style="{StaticResource AccentButtonStyle}" />

                <StackPanel
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="4">
                    <TextBlock FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}">Belum punya akun?</TextBlock>
                    <HyperlinkButton
                        MinHeight="0"
                        Padding="0"
                        Content="Hubungi Admin"
                        FontSize="14" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>