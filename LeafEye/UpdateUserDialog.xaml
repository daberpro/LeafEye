<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="LeafEye.UpdateUserDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Update Data User"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
    BorderThickness="1"
    CloseButtonStyle="{StaticResource ShadcnOutlineButtonStyle}"
    CloseButtonText="Batal"
    CornerRadius="8"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    PrimaryButtonStyle="{StaticResource ShadcnPrimaryButtonStyle}"
    PrimaryButtonText="Simpan Perubahan">

    <StackPanel
        Width="320"
        Margin="0,16,0,0"
        Spacing="16">

        <InfoBar
            x:Name="StatusInfoBar"
            IsClosable="True"
            IsOpen="False"
            Message="" />

        <StackPanel Spacing="8">
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Username" />
            <TextBox
                x:Name="UsernameTextBox"
                CornerRadius="6"
                IsReadOnly="True"
                KeyDown="UsernameTextBox_KeyDown"
                PlaceholderText="Masukkan username..." />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Password Baru (Kosongkan jika tidak diubah)" />
            <PasswordBox
                x:Name="PasswordBox"
                CornerRadius="6"
                KeyDown="PasswordBox_KeyDown"
                PlaceholderText="Masukkan password baru..." />
        </StackPanel>

        <CheckBox
            x:Name="IsAdminCheckBox"
            Margin="0,8,0,0"
            Content="Jadikan sebagai Admin" />

    </StackPanel>
</ContentDialog>