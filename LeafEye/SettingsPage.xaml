<Page
    x:Class="LeafEye.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:LeafEye"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32" VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Stretch" Spacing="32">

            <StackPanel Spacing="4">
                <TextBlock Style="{ThemeResource TitleLargeTextBlockStyle}" Text="Pengaturan" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Text="Kelola preferensi antarmuka aplikasi dan konfigurasi basis data lokal." />
            </StackPanel>

            <!-- Bagian: Antarmuka -->
            <StackPanel Spacing="8">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Antarmuka" />

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4,4,0,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Tema Aplikasi" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Pilih mode warna untuk aplikasi LeafEye." />
                        </StackPanel>

                        <RadioButtons
                            x:Name="ThemeSelection"
                            Grid.Column="1"
                            MaxColumns="3">
                            <RadioButton Content="Terang" Tag="Light" />
                            <RadioButton Content="Gelap" Tag="Dark" />
                            <RadioButton
                                Content="Sistem"
                                IsChecked="True"
                                Tag="Default" />
                        </RadioButtons>
                    </Grid>
                </Border>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,4,4">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Orientasi Navigasi" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Pilih posisi menu utama (Kiri atau Atas)." />
                        </StackPanel>

                        <ComboBox
                            x:Name="NavPositionCombo"
                            Grid.Column="1"
                            Width="160"
                            VerticalAlignment="Center"
                            SelectedIndex="0">
                            <ComboBoxItem Content="Kiri (Left)" Tag="Left" />
                            <ComboBoxItem Content="Atas (Top)" Tag="Top" />
                        </ComboBox>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Bagian: Pemrosesan Model (Inference) -->
            <StackPanel Spacing="8">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Pemrosesan Model (Inference)" />

                <!-- Hardware Acceleration -->
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4,4,0,0">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Akselerasi Perangkat Keras" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Pilih perangkat keras utama untuk proses inferensi AI." />
                        </StackPanel>

                        <ComboBox
                            x:Name="ComputeProviderCombo"
                            Grid.Column="1"
                            Width="160"
                            VerticalAlignment="Center"
                            SelectedIndex="0">
                            <ComboBoxItem Content="CPU (Default)" Tag="CPU" />
                            <ComboBoxItem Content="GPU (CUDA / DML)" Tag="GPU" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Confidence Threshold -->
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Confidence Threshold" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Batas minimal tingkat keyakinan (confidence) agar objek dianggap valid terdeteksi." />
                        </StackPanel>

                        <Slider
                            x:Name="ConfThresholdSlider"
                            Grid.Column="1"
                            Width="160"
                            VerticalAlignment="Center"
                            Maximum="1.0"
                            Minimum="0.1"
                            StepFrequency="0.05"
                            TickFrequency="0.1"
                            Value="0.5" />
                    </Grid>
                </Border>

                <!-- NMS Threshold -->
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="NMS Threshold" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Sensitivitas Non-Maximum Suppression untuk menyaring kotak deteksi yang saling bertumpuk." />
                        </StackPanel>

                        <Slider
                            x:Name="NmsThresholdSlider"
                            Grid.Column="1"
                            Width="160"
                            VerticalAlignment="Center"
                            Maximum="1.0"
                            Minimum="0.1"
                            StepFrequency="0.05"
                            TickFrequency="0.1"
                            Value="0.45" />
                    </Grid>
                </Border>

                <!-- Batch Size -->
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,4,4">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Ukuran Batch (Batch Size)" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Tentukan jumlah citra yang diproses secara bersamaan oleh model CNN dalam satu siklus memori." />
                        </StackPanel>

                        <NumberBox
                            x:Name="BatchSizeNumberBox"
                            Grid.Column="1"
                            Width="160"
                            VerticalAlignment="Center"
                            Maximum="128"
                            Minimum="1"
                            SpinButtonPlacementMode="Inline"
                            Value="16" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Bagian: Penyimpanan (ObjectBox) -->
            <StackPanel Spacing="8">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Penyimpanan (ObjectBox)" />

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel
                            Grid.Column="0"
                            Margin="0,0,24,0"
                            VerticalAlignment="Center">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="Maksimal Ukuran Database" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Text="Batas alokasi ukuran file ObjectBox di dalam disk penyimpanan (dalam Megabyte)." />
                        </StackPanel>

                        <NumberBox
                            x:Name="DbSizeNumberBox"
                            Grid.Column="1"
                            Width="160"
                            VerticalAlignment="Center"
                            Maximum="10240"
                            Minimum="100"
                            SpinButtonPlacementMode="Inline"
                            Value="1024" />
                    </Grid>
                </Border>

                <TextBlock
                    Margin="0,4,0,0"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="*Perubahan pada pengaturan penyimpanan memerlukan restart aplikasi untuk diterapkan ke ObjectBox Store." />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>